{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "npm ci --workspace=@influencer-platform/frontend && npm run build --workspace=@influencer-platform/frontend"
  },
  "deploy": {
    "startCommand": "node frontend/.next/standalone/server.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}