# =============================================================================
# 本番環境用 環境変数テンプレート
# =============================================================================
# このファイルはテンプレートです。実際の値を含みません。
# 本番環境では以下の手順で各変数を設定してください:
#   - GitHub Actions を使う場合: Settings > Secrets and variables > Actions
#   - コンテナ実行環境の場合: 実行時に --env-file または Secret Manager から注入
#
# 絶対にしてはいけないこと:
#   - このファイルに実際の値を書いてコミットする
#   - Dockerfile の ENV 命令に機密値を直接書く
#   - ログに環境変数の値を出力する
# =============================================================================

# -----------------------------------------------------------------------------
# データベース
# -----------------------------------------------------------------------------

# PostgreSQL 接続 URL
# 本番環境では ?sslmode=require を必ず付加すること
# 生成方法: AWS RDS / Cloud SQL のエンドポイントを使用
DATABASE_URL="postgresql://<db-user>:<db-password>@<db-host>:5432/<db-name>?sslmode=require"

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis サーバーのホスト名または IP アドレス
# AWS ElastiCache / Upstash などのエンドポイントを使用
REDIS_HOST=<redis-host>

# Redis のポート番号（デフォルト: 6379）
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# 認証・暗号化
# -----------------------------------------------------------------------------

# JWT 署名キー
# 生成方法: openssl rand -base64 32
# 要件: 最低 32 文字のランダム文字列
JWT_SECRET=<openssl-rand-base64-32-output>

# JWT 有効期限（本番では短めに設定すること）
JWT_EXPIRES_IN=15m

# Cookie 署名キー（JWT_SECRET とは別の値を使用すること）
# 生成方法: openssl rand -base64 32
COOKIE_SECRET=<openssl-rand-base64-32-output>

# Instagram アクセストークン暗号化キー（AES-256-GCM）
# 生成方法: openssl rand -hex 32
# 要件: ちょうど 64 文字の hex 文字列（32 bytes）
# 警告: ローテーション時は DB 内の暗号化済みトークンの再暗号化が必要
TOKEN_ENCRYPTION_KEY=<openssl-rand-hex-32-output>

# -----------------------------------------------------------------------------
# Instagram Graph API
# -----------------------------------------------------------------------------

# Meta Developer Console > 対象アプリ > 基本設定 から取得
# https://developers.facebook.com/
INSTAGRAM_CLIENT_ID=<meta-app-id>
INSTAGRAM_CLIENT_SECRET=<meta-app-secret>

# 本番環境のコールバック URL（Meta Developer Console に登録したものと一致させること）
INSTAGRAM_REDIRECT_URI=https://<your-domain>/api/v1/auth/instagram/callback

# -----------------------------------------------------------------------------
# Anthropic Claude API
# -----------------------------------------------------------------------------

# Anthropic Console > API Keys から取得
# https://console.anthropic.com/
# 警告: このキーはログに出力しないこと
ANTHROPIC_API_KEY=<sk-ant-your-key-here>

# 分析コメント生成に使用するモデル
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# アプリケーション設定
# -----------------------------------------------------------------------------

# バックエンドサーバーのリッスンポート
PORT=3001

# 実行環境（本番では必ず production を設定すること）
NODE_ENV=production

# 許可するフロントエンドオリジン
# 本番では正確なドメインを指定すること（ワイルドカード * は禁止）
CORS_ORIGIN=https://<your-frontend-domain>

# PDF/CSV レポートの出力ディレクトリ
# コンテナ内のパスを指定する（ボリュームマウント先と合わせること）
REPORT_OUTPUT_DIR=/app/storage/reports
