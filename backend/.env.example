# Database
DATABASE_URL="postgresql://user:password@localhost:5432/influencer_platform"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m

# Cookie signing secret (used by @fastify/cookie)
COOKIE_SECRET=change-me-in-production

# Instagram Graph API
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/v1/auth/instagram/callback

# App
PORT=3001
NODE_ENV=development

# CORS — frontend origin
CORS_ORIGIN=http://localhost:3000

# Report generation — output directory for PDF/CSV files
REPORT_OUTPUT_DIR=./storage/reports

# Anthropic Claude API
# APIキーは絶対にコードにハードコードしないこと。ログにも出力禁止。
ANTHROPIC_API_KEY=sk-ant-...
# 分析コメント生成に使用するモデル（Haikuで十分）
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
